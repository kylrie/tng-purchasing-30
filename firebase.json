{
    "firestore":  {
                      "database":  "tng-systems",
                      "rules":  "firestore.rules"
                  },
    "functions":  {
                      "source":  "functions",
                      "codebase":  "default",
                      "predeploy":  [
                                        "npm --prefix \"$RESOURCE_DIR\" run build"
                                    ]
                  },
    "hosting":  {
                    "site":  "tng-systems",
                    "public":  "dist",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ],
                    "headers":  [
                                    {
                                        "source":  "**",
                                        "headers":  [
                                                        {
                                                            "key":  "Cross-Origin-Opener-Policy",
                                                            "value":  "same-origin-allow-popups"
                                                        }
                                                    ]
                                    }
                                ]
                }
}
