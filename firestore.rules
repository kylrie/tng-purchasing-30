rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isOwner(resource) {
      return isSignedIn() && resource.data.requesterId == request.auth.uid;
    }
    
    function isSuperAdminOrAdmin() {
      return hasRole('SUPER_ADMIN') || hasRole('ADMIN');
    }

    // --- REQUISITIONS COLLECTION (SECURE) ---
    match /requisitions/{docId} {
      allow read: if isSignedIn(); // Allow any signed-in user to read
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        // 1. DRAFT Edits: Owner (or Super Admin) can edit anything if Draft
        (resource.data.status == 'DRAFT' && (isOwner(resource) || hasRole('SUPER_ADMIN'))) ||

        // 2. CANCEL: Owner, Admin, or Super Admin
        (
          request.resource.data.status == 'CANCELLED' && 
          (isOwner(resource) || hasRole('SUPER_ADMIN') || hasRole('ADMIN'))
        ) ||
        
        // 3. REFILE: Owner (or Super Admin), from REJECTED to PENDING
        (
          resource.data.status == 'REJECTED' &&
          (request.resource.data.status == 'BURF_PENDING_MANAGER' || request.resource.data.status == 'PRF_PENDING_MANAGER') &&
          (isOwner(resource) || hasRole('SUPER_ADMIN'))
        ) ||

        // 4. APPROVE: Manager/GM (or Super Admin) for BURF
        (
          resource.data.status == 'BURF_PENDING_MANAGER' &&
          (request.resource.data.status == 'BURF_PENDING_CIC' || request.resource.data.status == 'READY_FOR_PRF') &&
          (hasRole('MANAGER') || hasRole('GENERAL_MANAGER') || hasRole('SUPER_ADMIN'))
        ) ||

        // 5. APPROVE: CIC (or Super Admin) for BURF
        (
          resource.data.status == 'BURF_PENDING_CIC' &&
          request.resource.data.status == 'READY_FOR_PRF' &&
          (hasRole('CIC') || hasRole('SUPER_ADMIN'))
        ) ||
        
        // 6. APPROVE: Manager (or Super Admin) for PRF
        (
          resource.data.status == 'PRF_PENDING_MANAGER' &&
          request.resource.data.status == 'APPROVED_FOR_PAYMENT' &&
          (hasRole('MANAGER') || hasRole('GENERAL_MANAGER') || hasRole('SUPER_ADMIN'))
        ) ||

        // 7. REJECT: Any Approver (or Super Admin)
        (
          request.resource.data.status == 'REJECTED' &&
          (
             hasRole('MANAGER') || 
             hasRole('GENERAL_MANAGER') || 
             hasRole('CIC') || 
             hasRole('PURCHASING_OFFICER') ||
             hasRole('SUPER_ADMIN')
          )
        ) ||
        
        // 8. Finance Actions (Funds Release) (or Super Admin)
        (
           request.resource.data.status == 'FUNDS_RELEASED' &&
           (hasRole('FINANCE') || hasRole('SUPER_ADMIN'))
        )
      );
    }

    // --- USERS COLLECTION (SECURE) ---
    match /users/{userId} {
      // Anyone signed in can read user data (needed for displaying names, etc.)
      allow read: if isSignedIn();
      
      // Users can only update their own profile, or admins can update any
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdminOrAdmin());
      
      // Only admins can create or delete users
      allow create, delete: if isSuperAdminOrAdmin();
    }
    
    // --- BUSINESSES COLLECTION (SECURE) ---
    match /businesses/{id} {
      // Anyone signed in can read businesses (needed for dropdowns, etc.)
      allow read: if isSignedIn();
      
      // Only admins can create, update, or delete businesses
      allow create, update, delete: if isSuperAdminOrAdmin();
    }
    
    // --- NOTIFICATIONS COLLECTION (SECURE) ---
    match /notifications/{id} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Users can create notifications for themselves
      // System can create notifications (handled server-side)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Users can update/delete their own notifications
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // --- SUPPLIERS COLLECTION (SECURE) ---
    match /suppliers/{id} {
      // Any signed-in user can read suppliers (needed for dropdowns)
      allow read: if isSignedIn();
      
      // Only purchasing officers and admins can modify suppliers
      allow create, update, delete: if isSignedIn() && (
        hasRole('PURCHASING_OFFICER') || 
        hasRole('SUPER_ADMIN') ||
        hasRole('ADMIN')
      );
    }
    
    // --- CONFIG COLLECTION (SECURE) ---
    match /config/{document} {
      // Anyone signed in can read config (permissions, etc.)
      allow read: if isSignedIn();
      
      // Only super admins can update config
      allow write: if hasRole('SUPER_ADMIN');
    }
  }
}
